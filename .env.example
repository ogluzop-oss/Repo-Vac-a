# ============================================================
# Smart Manager AI — plantilla de configuración
# Copia este archivo a «.env» y rellena los valores reales.
#   cp .env.example .env      (o cópialo a mano en Windows)
# El archivo .env NO se versiona (está en .gitignore).
# ============================================================

# ── Base de datos (MariaDB / MySQL) — OBLIGATORIO ───────────
DB_HOST=127.0.0.1
DB_USER=root
DB_PASSWORD=admin123
DB_NAME=smart_manager_db
DB_PORT=3306
# SSL opcional (déjalo vacío si no usas SSL):
# DB_SSL_CA=

# ── Traducción IA / i18n Nivel 2 (opcional) ─────────────────
# Necesaria para traducir contenido dinámico (documentos, SOMA)
# y para ejecutar backfill_idiomas.py. Sin ella, la app cae a
# inglés en las claves no traducidas (sigue 100% funcional).
ANTHROPIC_API_KEY=
# Modelo de traducción (por defecto: claude-haiku-4-5-20251001):
# SMART_MANAGER_TRANSLATE_MODEL=claude-haiku-4-5-20251001

# ── Envío de correo (albaranes/informes por email) — opcional ──
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
