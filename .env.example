# Variables de entorno para despliegue SaaS (FASE SAAS-M). Copiar a .env.
DB_HOST=db
DB_USER=root
DB_PASSWORD=admin123
DB_NAME=smart_manager_db
DB_PORT=3306
API_CORS_ORIGINS=https://app.tudominio.com
SMART_MANAGER_JWT_SECRET=genera-un-secreto-fuerte
# Almacenamiento externo opcional (object storage) para documentos/backups por tenant.
SM_OBJECT_STORAGE_URL=

# ── Correo corporativo · Gmail API (OAuth) ──────────────────
# Opcional. Solo necesario para ENVIAR correo vía API de Gmail con OAuth (la
# recepción usa IMAP y el envío también admite SMTP con contraseña de aplicación).
# Orden de resolución del client OAuth: 1) estas variables, 2) secret manager,
# 3) GOOGLE_OAUTH_CLIENT_FILE, 4) documentos/google_oauth_client.json (fallback heredado).
# RECOMENDADO: usar estas variables (o un secret manager) en vez de un JSON en disco.
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
# Fallback heredado (ruta a un client_secret.json de Google Cloud):
# GOOGLE_OAUTH_CLIENT_FILE=
# Backend de secretos (fernet por defecto; 'vault' = punto de extensión KMS/Vault):
# SM_SECRET_BACKEND=fernet
